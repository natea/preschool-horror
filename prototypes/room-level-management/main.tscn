;; === ENTRY HALL (6m x 5m) — leftmost room ===
;; Center at (-7, 0, 0) so it connects to classroom via doorway

[node name="EntryHall" type="Node3D" parent="Preschool"]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, -7, 0, 0)

[node name="Floor" type="CSGBox3D" parent="Preschool/EntryHall"]
